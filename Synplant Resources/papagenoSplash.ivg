/**
 * @file Genopatch Animated Logo
 * @author Fredrik Lidström
 * @copyright Fredrik Lidström 2022-05-20
 *
 * @param {number} [animationProps] - bind to papagenoUI.splash.animationProps
 * @param {textColor} color - text color
 * @param {pinColor} color - pin color
 */

format IVG-2 requires:IMPD-1

include "support.ivg"

bounds 0,0,460,460

offset {$width/2},{$height/2}
scale {250 / 2048}

context [
	$split $animationProps into:s1,s2,s3,r1,r2,r3,o1,o2,o3,o4

  offset 0,-150
	context [ // BUD 1
		scale $s1
		fill opacity:$o1
		rotate $r1
		fill $pinColor
		path svg:[m-89 235-56-30L-7-4 8 4z]
		fill #004739
		path svg:[M-202 208c91 0 166 75 166 166-9 221-324 221-333 0 0-92 75-166 167-166m0-22A188 188 0 1 0-29 301c-28-68-99-116-173-115Z]
		fill #007059
		path svg:[M-202 236a138 138 0 0 0-98 236c51 54 144 54 195 0 87-87 25-236-97-236z]
	]
	
	context [ // BUD 2
		scale $s2
		fill opacity:$o2
		rotate $r2
		fill $pinColor
		path svg:[M183-30v60L0 9V-9z]
		fill #07484a
		path svg:[M396 204c-113 0-204-91-204-204 11-271 398-271 409 0 0 113-92 204-205 204m0 28A232 232 0 1 0 183 91c35 83 122 142 213 141z]
		fill #006e71
		path svg:[M396 170c151 0 227-183 121-290a170 170 0 1 0-120 290Z]
	]
	
	context [ // BUD 3
		scale $s3
		fill opacity:$o3
		rotate $r3
		fill $pinColor
		path svg:[m-116-187 56-25L9-4-8 4z]
		fill #164a5e
		path svg:[M-202-719c143 0 259 116 259 259-14 344-505 344-519 0 0-143 116-259 260-259m0-34A294 294 0 1 0 69-574a295 295 0 0 0-271-179z]
		fill #0d6281
		path svg:[M-202-675a216 216 0 0 0-153 368c80 83 225 83 305 0a216 216 0 0 0-152-368z]
	]
	
]

offset -1024,-1024

// TEXT
fill opacity:$o4
fill $textColor
