// CREDITS
context [
  offset $center,225
  for row in:[
    [15,,[created by]]
    [16,yes,[Magnus & Fredrik Lidstr\xf6m]]
    [7,,[]]
    [13.5,,[\xa9$copyright NuEdge Development. All rights reserved.]]
    [9,,[]]
    [13.5,,[using: Symbiosis by NuEdge, zlib by Jean-loup Gailly and]]
    [13.5,,[Mark Adler, LibPNG by G. Randers-Pehrson, and VST PlugIn]]
    [13.5,,[Technology by Steinberg. VST is a trademark of Steinberg Media]]
    [13.5,,[Technologies GmbH, registered in Europe and other countries.]]
  ] [
    $split $row into:size,bold,line
    font size:$size outline:{$bold == "yes" ? "[$fontColor width:0.3]" : none} tracking:{$bold == "yes" ? 0.04 : 0.01}
    TEXT at:0,0 anchor:center $line
    offset 0,{$size*1.6}
  ];
]

/* VERSION */
context [
  options aa-gamma:1.2
  font size:12
  TEXT at:{$width-20},{$height-42} anchor:right [\ ($number)]
  font size:16
  TEXT anchor:right [v$version]

  font size:14 tracking:0.01
  local left
  TEXT at:{$width-20},{$height-20} anchor:right caret:left [https:\/\/soniccharge.com]
  pen $fontColor width:0.5
  PATH svg:[M{$left},{$height-18} H{$width-20}]
]
