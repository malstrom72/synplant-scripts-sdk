text.color = $color0 // text #d6e6c4
leaf3.color = $color1 // 1st #313625
leaf6.color = $color2 // 2nd #444F34
leaf9.color = $color5 // 3rd #8E965E
leaf7.color = $color4 // 4th #6F7A4C
leaf1.color = $color1 // 5th #313625
leaf4.color = $color2 // 6th #444F34
leaf5.color = $color3 // 7th #657048
leaf2.color = $color2 // 8th #444F34
leaf8.color = $color2 // 9th #444F34

text.width = 30
leaf3.width = 90
leaf6.width = 200
leaf9.width = 150
leaf7.width = 100
leaf1.width = 100
leaf4.width = 210
leaf5.width = 230
leaf2.width = 100
leaf8.width = 160


leaf3.start = 1.6 // curl
leaf6.start = 0   //
leaf9.start = 0   //
leaf7.start = 1.8 // curl
leaf1.start = 1.6 // curl
leaf4.start = 0   //
leaf5.start = 0   //
leaf2.start = 1.7 // curl
leaf8.start = 0.6 // curl

leaf3.speed = 0.2 // curl
leaf6.speed = 0.2 //
leaf9.speed = 0.3 //
leaf7.speed = 0.3 // curl
leaf1.speed = 0.3 // curl
leaf4.speed = 0.3 //
leaf5.speed = 0.2 //
leaf2.speed = 0.2 // curl
leaf8.speed = 0.5 // curl

local w = 0
for i from:1 to:9 [
	if { $animate } [
		a = { $frame * $speed }
		t = { ($a - $leaf($i).start) * $leaf($i).speed }
		w = { $t >= 1.0 ? 0 : $leaf($i).width * ( 1.0 - $t ) }
	]
	if {$w < 220} [
		context [
			if { $animate } [
				mask inverted:yes [
					pen 1 width:30
					PATH svg:{$text.path}
					if {$w > 0} [ 
						pen 1 width:{$w}
						fill 0
						PATH svg:{$leaf($i).path}
					]
				]
			]
			if { $snow > 0 } [
				context [
					fill white opacity:$snow
					repeat 6 [
						offset 0,{$snow*8/-2};
						PATH svg:{ $leaf($i).path }
					]
				]
			]
			fill { $leaf($i).color }
			PATH svg:{ $leaf($i).path }	
		]
	]
]

o = 1.0
context [
	if { $animate } [
		if { $frame < 0.5 } [
			o = {$frame *2}
		]
		mask inverted:yes [
			pen 1 width:25
			fill 0
			PATH svg:{$text.path}
		]
	] else:[
		pen #cc222222 width:25
	]
	fill {$text.color} opacity:$o
	PATH svg:{$text.path}
]
