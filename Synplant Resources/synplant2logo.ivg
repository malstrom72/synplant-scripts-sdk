/**
 * @file Synplant Animated Logo
 * @author Fredrik Lidström
 * @copyright Fredrik Lidström 2013-11-01
 *
 * @param {number} [frame] - bind to about.animation
 * @param {color[]} [recolor] - bind to main.logoColoringBook.colors
 * @param {number} [snow=0] - bind to main.logoColoringBook.snow
 */
 
format IVG-2 requires:IMPD-1

bounds 0,0,500,500

reset
offset 0,4

scale 0.1

// offset 17,48
// scale 1.055

local animate = { def(frame) }
local speed = 0.6

// Default colors
local color0 = "#D6E6C4"
local color1 = "#485037"
local color2 = "#4D593C"
local color3 = "#5F6A45"
local color4 = "#6B774A"
local color5 = "#656A44"

if { def(recolor) } [
	local i = 0
	for c in:$recolor [
		color$i = $c
		i = { $i + 1 }
	]
]
local snow = { def(snow) ? $snow : 0 }

