include: ../../Synplant Resources/Synplant2.schema
resources: ../
resources: ../../Synplant Resources

<actions> = <synplant2Action>
        | { action: "skinChooser.initGUI", params: { *: <int> } }
        | { action: "skinChooser.animate" }
        | { action: "skinChooser.flipPage", params: "left" | "right" }
        | { action: "skinChooser.rescan" }
