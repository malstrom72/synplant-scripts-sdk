['1.metaChars'] = "(metaTag / (!'[' (('\\\\' .) / .))+)\n";
['1.metaLowercase'] = "'[lowercase]' (!'[/lowercase]' metaTag / metaChars)* '[/lowercase]'\n";
['1.metaMac'] = "'[mac]' (!'[/mac]' metaTag / metaChars)* '[/mac]'\n";
['1.metaParams'] = ".*\n";
['1.metaTag'] = "metaVar / metaWindows / metaMac / metaXLate / metaUppercase / metaLowercase / metaTrim\n                       / metaCapitalize / metaTitle\n";
['1.metaText'] = "(metaTag / metaChars)*\n";
['1.metaTitle'] = "'[title]' (!'[/title]' metaTag / metaChars)* '[/title]'";
['1.metaTrim'] = "'[trim]' (!'[/trim]' metaTag / metaChars)* '[/trim]'\n";
['1.metaUppercase'] = "'[uppercase]' (!'[/uppercase]' metaTag / metaChars)* '[/uppercase]'\n";
['1.metaVar'] = "'[var]' (!'[/var]' metaTag / metaChars)* '[/var]'\n";
['1.metaVariable'] = "'can:' metaAction (',' metaParams)?\n                       / 'checked:' metaAction (',' metaParams)?\n                       / ('lowercase:'\n                         / 'modifiable:'\n                         / 'trimmed:'\n                         / 'uppercase:'\n                         / 'translated:'\n                       ) (metaVariable / identifier)\n                       / 'calculated:' _ metaCalced\n                       / 'text:' .*\n                       / 'metatext:' metaText\n";
['1.metaWindows'] = "'[windows]' (!'[/windows]' metaTag / metaChars)* '[/windows]'\n";
['1.metaXLate'] = "'[xlate]' (!'[/xlate]' metaTag / metaChars)* '[/xlate]'\n";
['1.modifierMask'] = "'shift' / 'control' / 'alt' / 'command' / 'windows' / 'mac'";
['1.numericColor'] = 'hexColor / decimalColor';
['1.positiveIntLiteral'] = "[+]? [0-9]+\n";
