['1.metaCalcedGroup'] = "('-' _)* ('(' _ metaCalced ')' / [0-9]+ ('.' [0-9]+)? / metaCalcedSymbol) _\n";
['1.metaCalcedSymbol'] = "[a-zA-Z0-9$_.:]+\n";
