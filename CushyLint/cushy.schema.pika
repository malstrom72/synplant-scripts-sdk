['1.clickMask'] = "typeMask ('+' modifierMask)*\n";
['1.decimalColor'] = "('rgb(' / 'hsv(') floatExpr ',' floatExpr ',' floatExpr (',' floatExpr)? ')'\n";
['1.floatExpr'] = "floatGroup _ ([-+*/] _ floatGroup _)*\n";
['1.floatGroup'] = "('-' _)* ('(' _ floatExpr ')' / [0-9]+ ('.' [0-9]+)? / '$') _\n";
